# App
DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=imageopt
DB_PASSWORD=your_secure_password
DB_NAME=imageopt
DB_ROOT_PASSWORD=your_root_password

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
MAX_FILE_SIZE_MB=50

# Auto-delete undownloaded files after N hours
AUTO_DELETE_HOURS=24

# Image quality (1-95)
DEFAULT_QUALITY=85

# CORS — comma-separated list of allowed origins (set to your Vercel URL in production)
CORS_ORIGINS=["https://your-app.vercel.app"]
